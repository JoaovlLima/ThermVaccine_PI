<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="thermvaccine-pu" transaction-type="RESOURCE_LOCAL">

        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <!-- Classes mapeadas como entidade serão detectadas automaticamente -->

        <properties>
            <!-- Conexão com Supabase (PostgreSQL) -->
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <property name="jakarta.persistence.jdbc.url"    value="jdbc:postgresql://SEU_HOST.supabase.co:5432/postgres"/>
            <property name="jakarta.persistence.jdbc.user"   value="SEU_USUARIO"/>
            <property name="jakarta.persistence.jdbc.password" value="SUA_SENHA"/>

            <!-- Dialeto do PostgreSQL para o Hibernate -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>

            <!-- Cria/atualiza as tabelas automaticamente com base nas entidades -->
            <!-- Valores possíveis: create | create-drop | update | validate | none -->
            <property name="hibernate.hbm2ddl.auto" value="update"/>

            <!-- Mostra o SQL gerado pelo Hibernate no console (útil para debug) -->
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>

    </persistence-unit>

</persistence>
